# Neon Postgres (pooled connection string)
DATABASE_URL=

# Stack Auth (https://app.stack-auth.com)
NEXT_PUBLIC_STACK_PROJECT_ID=
NEXT_PUBLIC_STACK_PUBLISHABLE_CLIENT_KEY=
STACK_SECRET_SERVER_KEY=

# Plaid (https://dashboard.plaid.com)
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox

# 32 bytes hex (generate: openssl rand -hex 32). Encrypts Plaid access
# tokens at rest. Treat like a database password; never commit.
ENCRYPTION_KEY=

# Anthropic Claude (https://console.anthropic.com). Powers v0.3
# auto-categorization with claude-haiku-4-5.
ANTHROPIC_API_KEY=

# Stripe (https://dashboard.stripe.com/test/apikeys). Powers invoice
# pay pages via Stripe Checkout. Use test keys until ready for real money.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
